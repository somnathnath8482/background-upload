{
  "name": "background-upload",
  "version": "0.1.0",
  "description": "Production-ready React Native background upload module for presigned PUT URLs",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "android",
    "ios",
    "build",
    "react-native.config.js",
    "!android/build",
    "!ios/build",
    "!**/*.log"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('build',{recursive:true,force:true})\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android"
  },
  "keywords": [
    "react-native",
    "background-upload",
    "presigned-url",
    "turbomodule"
  ],
  "repository": "https://github.com/somnathnath8482/background-upload",
  "bugs": {
    "url": "https://github.com/somnathnath8482/background-upload/issues"
  },
  "author": "Somnath nath <somnathnath8482@gmail.com> (https://github.com/somnathnath8482)",
  "license": "MIT",
  "homepage": "https://github.com/somnathnath8482/background-upload#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "codegenConfig": {
    "name": "BackgroundUploadSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.easy.bg"
    }
  }
}
