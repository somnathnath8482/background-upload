{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./build",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": ["ES2020"]
  },
  "include": ["./src"],
  "exclude": ["example", "build", "node_modules"]
}
